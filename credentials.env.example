# API Keys for Enterprise Realtime Voice Agent
# Copy this to credentials.env and fill in your keys:
#   cp credentials.env.example credentials.env

# Deepgram - Speech-to-Text (https://deepgram.com)
# Free tier: 12,000 minutes/year
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs - Text-to-Speech (https://elevenlabs.io)
# Free tier: 10,000 characters/month
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI - LLM (https://platform.openai.com)
# Or use self-hosted vLLM (see README)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI-compatible endpoint
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL=gpt-4.1-mini

# Optional: HuggingFace token for model downloads
# HF_TOKEN=your_hf_token_here
